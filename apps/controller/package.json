{
  "name": "@replaypilot/controller",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build -w @replaypilot/shared && vite",
    "build": "npm run build -w @replaypilot/shared && tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "npm run build -w @replaypilot/shared && tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts"
  },
  "dependencies": {
    "@replaypilot/shared": "0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.14"
  }
}
