{
  "name": "@replaypilot/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build -w @replaypilot/shared && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "executor": "tsx src/local/localExecutor.ts",
    "executor:watch": "tsx src/local/localExecutor.ts --watch=true",
    "typecheck": "npm run build -w @replaypilot/shared && tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@google/genai": "^0.14.1",
    "@replaypilot/shared": "0.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "playwright": "^1.52.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
